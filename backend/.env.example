PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/newshub?retryWrites=true&w=majority
JWT_SECRET=<random_string_min_32_chars>
JWT_EXPIRES_IN=7d

# NewsAPI.org — 100 req/day free — https://newsapi.org
NEWS_API_KEY=<your_newsapi_key>

# GNews API — 100 req/day free — https://gnews.io
# Supports Telugu (te) and Hindi (hi) natively
GNEWS_API_KEY=<your_gnews_key>

# MediaStack — 500 req/month free — https://mediastack.com
# 7,500+ sources, regional vernacular press
MEDIASTACK_API_KEY=<your_mediastack_key>

CLIENT_URL=http://localhost:3000
